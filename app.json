{
  "expo": {
    "name": "Golf Performance OS",
    "slug": "golf-training-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "golfos",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F0E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ianhodge.golfos"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F0E"
      },
      "package": "com.ianhodge.golfos"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D0F0E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
